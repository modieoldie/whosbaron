---
import Base from "../layouts/Base.astro";
import { profile } from "../data/content";
---

<Base>
  <canvas id="scene-canvas"></canvas>

  <div id="loader" data-visible="true">
    <p class="marker">Building the room</p>
    <div id="loader-bar"></div>
  </div>

  <div id="hover-label" data-visible="false"></div>

  <!-- One dot per desk prop; filled in and positioned by the scene. -->
  <div id="prop-markers" data-visible="false" aria-hidden="true"></div>

  <div id="intro" data-visible="false">
    <p class="marker mb-5">{profile.location}</p>
    <h1 class="font-serif text-5xl leading-[0.95] font-light tracking-tight text-bone sm:text-6xl">
      who's <span class="italic text-brass">baron</span>?
    </h1>
  </div>

  <!-- `data-view` lets the stylesheet treat each view's line on its own terms:
       they are different lengths, and only the short one can hold a phone to a
       single line. Kept in the markup so it is right before the scene boots. -->
  <div id="hint" data-visible="false" data-view="orbit">
    <!-- Rewritten per view by the scene; this is the orbit copy. -->
    <p id="hint-text" class="marker">Drag to look around · Click the desk</p>
  </div>

  <button id="back-btn" class="ghost" data-visible="false" type="button">← Back to the room</button>

  <!-- Narrow viewports read one monitor at a time, so they need a way to reach
       the other one. Never shown on a desktop, which frames both at once. -->
  <div id="screen-switch" data-visible="false">
    <button type="button" data-active="true">Projects</button>
    <button type="button" data-active="false">About</button>
  </div>

  <aside id="card" data-visible="false" aria-live="polite">
    <button
      id="card-close"
      class="absolute top-4 right-4 font-mono text-xs text-ash-dim transition-colors hover:text-brass"
      type="button"
      aria-label="Close">✕</button
    >
    <p id="card-eyebrow" class="marker"></p>
    <h2 id="card-title" class="mt-3 font-serif text-3xl leading-tight font-light text-bone"></h2>
    <p id="card-body" class="mt-4 text-sm leading-relaxed text-ash"></p>
    <div id="card-meta" class="mt-5 flex flex-wrap gap-2" data-visible="false"></div>
    <a id="card-link" class="ghost mt-6 inline-block" data-visible="false" href="#"></a>
  </aside>

  <nav id="corner-links">
    <a
      href={profile.github}
      target="_blank"
      rel="noopener noreferrer"
      class="font-mono text-[0.6875rem] tracking-[0.2em] text-ash uppercase transition-colors hover:text-brass"
      >GitHub</a
    >
    <a
      href={profile.linkedin}
      target="_blank"
      rel="noopener noreferrer"
      class="font-mono text-[0.6875rem] tracking-[0.2em] text-ash uppercase transition-colors hover:text-brass"
      >LinkedIn</a
    >
    <a
      href="/text"
      class="font-mono text-[0.6875rem] tracking-[0.2em] text-ash-dim uppercase transition-colors hover:text-brass"
      >Text version</a
    >
  </nav>

  <noscript>
    <div
      style="position:fixed;inset:0;z-index:100;display:grid;place-content:center;gap:1rem;background:#0a0a0b;padding:2rem;text-align:center"
    >
      <h1 class="font-serif text-5xl font-light">who's <span class="text-brass italic">baron</span>?</h1>
      <p class="text-ash max-w-md text-sm">
        The room needs JavaScript. Everything in it is also written down, plainly.
      </p>
      <a href="/text" class="ghost justify-self-center">Read the text version</a>
    </div>
  </noscript>
</Base>

<script>
  import { boot } from "../scene/main";

  boot().catch((error) => {
    // WebGL can fail for reasons outside our control: a blocklisted driver, a
    // locked-down browser. Don't strand the visitor on a black page.
    console.error("[scene] failed to start", error);
    window.location.replace("/text");
  });
</script>
